# --- Database (compose builds DATABASE_URL from these) ---
APP_SERVER=localhost
APP_PORT=5432
APP_DATABASE=issuedeskdevl
APP_USER=postgres
APP_PASSWORD=postgres

# --- App ---
PORT=8080
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_BYTES=26214400

# --- First-boot admin seed (only applied when users table is empty) ---
SEED_ADMIN=true
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@issuedesk.local
SEED_ADMIN_PASSWORD=admin123

# --- Logging ---
RUST_LOG=info,issuedesk_api=debug,tower_http=info
