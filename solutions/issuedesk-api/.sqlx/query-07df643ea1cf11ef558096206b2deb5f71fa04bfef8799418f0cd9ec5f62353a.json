  "query": "SELECT p.id, p.key, p.name, p.description, p.issue_seq, p.created_by,\n                      p.created_at, p.updated_at\n               FROM projects p\n               JOIN project_members m ON m.project_id = p.id\n               WHERE m.user_id = $1\n               ORDER BY p.key",
