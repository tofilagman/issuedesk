  "query": "SELECT il.issue_id, l.id, l.project_id, l.name, l.color\n           FROM issue_labels il\n           JOIN labels l ON l.id = il.label_id\n           WHERE il.issue_id = ANY($1)\n           ORDER BY l.name",
