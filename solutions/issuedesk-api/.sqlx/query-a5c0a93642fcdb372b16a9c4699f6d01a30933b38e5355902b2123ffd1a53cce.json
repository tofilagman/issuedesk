{
  "db_name": "PostgreSQL",
  "query": "SELECT c.id, c.issue_id, c.author_id, u.display_name as author_name,\n                  c.body, c.created_at, c.updated_at\n           FROM comments c\n           JOIN users u ON u.id = c.author_id\n           WHERE c.issue_id = $1\n           ORDER BY c.created_at",
